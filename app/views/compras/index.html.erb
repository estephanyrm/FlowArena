<% content_for :title, "Mis Boletos – Flow Arena" %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap');

  .boletos-root * { font-family: 'DM Sans', sans-serif; }
  .boletos-root h1, .boletos-root h2, .font-display { font-family: 'Syne', sans-serif; }

  .ticket-card {
    position: relative;
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 16px 0 rgba(109,40,217,0.07);
    transition: transform 0.22s cubic-bezier(.34,1.56,.64,1), box-shadow 0.22s ease;
  }
  .ticket-card:hover {
    transform: translateY(-4px) scale(1.01);
    box-shadow: 0 12px 40px 0 rgba(109,40,217,0.13);
  }
  .ticket-notch-left {
    position: absolute; left: -10px; top: 50%; transform: translateY(-50%);
    width: 20px; height: 20px; background: #f3e8ff; border-radius: 50%; z-index: 2;
  }
  .ticket-notch-right {
    position: absolute; right: -10px; top: 50%; transform: translateY(-50%);
    width: 20px; height: 20px; background: #f3e8ff; border-radius: 50%; z-index: 2;
  }
  .ticket-dashed {
    border-top: 2px dashed #e9d5ff;
    margin: 0 12px;
  }
  .badge-completado { background: #dcfce7; color: #16a34a; }
  .badge-pendiente  { background: #fef9c3; color: #b45309; }
  .badge-otro       { background: #f3f4f6; color: #6b7280; }

  .empty-state { animation: fadeUp 0.5s ease both; }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .ticket-card { animation: fadeUp 0.4s ease both; }
  .ticket-card:nth-child(1) { animation-delay: 0.05s; }
  .ticket-card:nth-child(2) { animation-delay: 0.10s; }
  .ticket-card:nth-child(3) { animation-delay: 0.15s; }
  .ticket-card:nth-child(4) { animation-delay: 0.20s; }

  .zona-bar {
    width: 4px; border-radius: 4px; align-self: stretch; flex-shrink: 0;
  }
  .qr-mini {
    width: 56px; height: 56px; border-radius: 8px;
    border: 1.5px solid #e9d5ff;
    display: flex; align-items: center; justify-content: center;
    background: #faf5ff; flex-shrink: 0;
  }
  .filter-btn {
    padding: 6px 16px; border-radius: 99px; font-size: 13px; font-weight: 600;
    border: 1.5px solid transparent; cursor: pointer; transition: all 0.15s;
    background: #f5f3ff; color: #7c3aed;
  }
  .filter-btn.active, .filter-btn:hover {
    background: #7c3aed; color: #fff; border-color: #7c3aed;
  }

  /* Mini QR SVG pattern */
  .mini-qr { image-rendering: pixelated; }
</style>

<section class="boletos-root bg-purple-50 min-h-screen pb-16">

  <%# HEADER STRIP %>
  <div class="bg-white border-b border-purple-100 shadow-sm">
    <div class="max-w-4xl mx-auto px-4 py-5 flex items-center justify-between gap-4">
      <div>
        <p class="text-xs text-purple-400 font-semibold uppercase tracking-widest mb-0.5">Flow Arena</p>
        <h1 class="font-display text-2xl md:text-3xl font-800 text-gray-900 leading-tight" style="font-weight:800;">
          Mis Boletos
        </h1>
      </div>
      <div class="flex items-center gap-3">
        <% compras_total = current_user.compras.includes(:boletos, :pago, zonas: :evento).order(created_at: :desc) %>
        <div class="text-center bg-purple-50 rounded-xl px-4 py-2 border border-purple-100">
          <p class="text-xl font-display font-800 text-purple-700" style="font-weight:800;"><%= compras_total.count %></p>
          <p class="text-xs text-gray-400 font-medium">compras</p>
        </div>
        <div class="text-center bg-purple-50 rounded-xl px-4 py-2 border border-purple-100">
          <p class="text-xl font-display font-800 text-purple-700" style="font-weight:800;">
            <%= compras_total.sum { |c| c.boletos.count } %>
          </p>
          <p class="text-xs text-gray-400 font-medium">boletos</p>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 pt-6">

    <%# FILTROS %>
    <div class="flex items-center gap-2 mb-6 flex-wrap">
      <button class="filter-btn active" onclick="filtrar('todos', this)">Todos</button>
      <button class="filter-btn" onclick="filtrar('completado', this)">Pagados</button>
      <button class="filter-btn" onclick="filtrar('pendiente', this)">Pendientes</button>
    </div>

    <% compras = current_user.compras.includes(:boletos, :pago, zonas: :evento).order(created_at: :desc) %>

    <% if compras.empty? %>
      <%# EMPTY STATE %>
      <div class="empty-state flex flex-col items-center justify-center py-24 text-center">
        <div class="w-20 h-20 rounded-2xl bg-purple-100 flex items-center justify-center mb-5">
          <svg class="w-10 h-10 text-purple-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
          </svg>
        </div>
        <h2 class="font-display text-xl font-bold text-gray-700 mb-2">Aún no tienes boletos</h2>
        <p class="text-sm text-gray-400 mb-6 max-w-xs">Explora los eventos disponibles y compra tus entradas.</p>
        <%= link_to root_path, class: "inline-flex items-center gap-2 bg-purple-700 hover:bg-purple-800 text-white font-bold text-sm px-6 py-3 rounded-xl transition-all active:scale-95" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
          Ver eventos
        <% end %>
      </div>

    <% else %>
      <div class="flex flex-col gap-4" id="lista-compras">
        <% compras.each do |compra| %>
          <%
            boleto_rep = compra.boletos.first
            zona       = boleto_rep&.zona
            evento     = zona&.evento
            color_zona = { "Diamante" => "#7C3AED", "VIP" => "#2563EB", "Preferencial" => "#059669", "General" => "#D97706" }[zona&.nombre] || "#7C3AED"
            es_pagado  = compra.estado == "completado" || compra.pago&.estado == true
            estado_label = es_pagado ? "Pagado" : compra.estado&.capitalize || "Pendiente"
            badge_class  = es_pagado ? "badge-completado" : (compra.estado == "pendiente" ? "badge-pendiente" : "badge-otro")
          %>

          <div class="ticket-card" data-estado="<%= compra.estado %>">
            <%# Notches decorativos %>
            <div class="ticket-notch-left"></div>
            <div class="ticket-notch-right"></div>

            <%# CABECERA COLOREADA %>
            <div class="px-6 pt-5 pb-4 flex items-start justify-between gap-4" style="background: linear-gradient(135deg, <%= color_zona %>18 0%, white 70%);">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1.5">
                  <span class="inline-block w-2.5 h-2.5 rounded-full flex-shrink-0" style="background: <%= color_zona %>"></span>
                  <span class="text-xs font-bold uppercase tracking-widest" style="color: <%= color_zona %>">
                    Zona <%= zona&.nombre || "—" %>
                  </span>
                  <span class="inline-flex items-center gap-1 text-xs font-bold px-2 py-0.5 rounded-full <%= badge_class %>">
                    <%= es_pagado ? "✓" : "◷" %> <%= estado_label %>
                  </span>
                </div>
                <h2 class="font-display text-lg font-bold text-gray-900 leading-tight truncate" style="font-weight:700;">
                  <%= evento&.nombre || "Evento" %>
                </h2>
                <% if evento %>
                  <p class="text-xs text-gray-400 mt-1">
                    <%= I18n.l(evento.fecha, format: :long) rescue evento.fecha.strftime("%d/%m/%Y") %>
                    <%= evento.hora.strftime("%I:%M %p") %>
                  </p>
                <% end %>
              </div>
              <%# Mini QR visualizado por token %>
              <div class="qr-mini flex-shrink-0">
                <svg width="40" height="40" viewBox="0 0 9 9" class="mini-qr" xmlns="http://www.w3.org/2000/svg">
                  <rect width="9" height="9" fill="white"/>
                  <% if boleto_rep %>
                    <% bits = boleto_rep.token_qr.gsub('-','').chars.map { |c| c.to_i(16) } %>
                    <% (0..8).each do |r| %>
                      <% (0..8).each do |c| %>
                        <% on = (r < 3 && c < 3) || (r < 3 && c > 5) || (r > 5 && c < 3) || (bits[(r*9+c) % bits.length].to_i > 7) %>
                        <% if on && !((r==1||r==2) && (c==1||c==2)) && !((r==1||r==2) && (c==6||c==7)) && !((r==6||r==7) && (c==1||c==2)) %>
                          <rect x="<%= c %>" y="<%= r %>" width="1" height="1" fill="#4c1d95"/>
                        <% end %>
                      <% end %>
                    <% end %>
                  <% end %>
                </svg>
              </div>
            </div>

            <%# LÍNEA CORTE %>
            <div class="ticket-dashed"></div>

            <%# DETALLES %>
            <div class="px-6 py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
              <div class="flex items-center gap-5 text-sm flex-wrap">
                <div>
                  <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-0.5">Boletos</p>
                  <p class="font-bold text-gray-800"><%= compra.cantidad %> entrada<%= compra.cantidad > 1 ? "s" : "" %></p>
                </div>
                <div>
                  <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-0.5">Total</p>
                  <p class="font-bold text-gray-800">
                    $<%= ActiveSupport::NumberHelper.number_to_delimited(compra.precio_total.to_i, delimiter: '.') %> COP
                  </p>
                </div>
                <div>
                  <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-0.5">Orden</p>
                  <code class="text-xs font-mono bg-purple-50 text-purple-700 px-2 py-0.5 rounded"><%= compra.numero_orden %></code>
                </div>
                <div>
                  <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-0.5">Fecha compra</p>
                  <p class="font-bold text-gray-800 text-xs"><%= compra.created_at.strftime("%d/%m/%Y %H:%M") %></p>
                </div>
              </div>

              <%# ACCIÓN %>
              <% if es_pagado %>
                <%= link_to compra_path(compra), class: "flex-shrink-0 inline-flex items-center gap-2 bg-purple-700 hover:bg-purple-800 text-white font-bold text-sm px-5 py-2.5 rounded-xl transition-all active:scale-95" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                  </svg>
                  Ver boleto
                <% end %>
              <% else %>
                <%= link_to pago_compra_path(compra), class: "flex-shrink-0 inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-bold text-sm px-5 py-2.5 rounded-xl transition-all active:scale-95" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                  </svg>
                  Completar pago
                <% end %>
              <% end %>
            </div>
          </div>

        <% end %>
      </div>
      <div class="mt-8 text-center">
        <%= link_to root_path, class: "inline-flex items-center gap-2 text-purple-700 font-semibold text-sm hover:underline" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Explorar más eventos
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<script>
  function filtrar(estado, btn) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    document.querySelectorAll('#lista-compras .ticket-card').forEach(card => {
      const cardEstado = card.dataset.estado;
      const mostrar = estado === 'todos' ||
                      (estado === 'completado' && cardEstado === 'completado') ||
                      (estado === 'pendiente' && cardEstado === 'pendiente');
      card.style.display = mostrar ? '' : 'none';
    });
  }
</script>

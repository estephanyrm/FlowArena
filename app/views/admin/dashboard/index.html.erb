<%# Métricas principales %>
<div class="px-4 pt-4">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Panel de Control</h1>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4 mb-6">

    <%# Widget: Ingresos %>
    <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700">
      <div class="flex items-center">
        <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center bg-green-100 rounded-lg dark:bg-green-900">
          <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"></path>
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="ml-4">
          <span class="text-sm text-gray-500 dark:text-gray-400">Ingresos totales</span>
          <div class="text-2xl font-bold text-gray-900 dark:text-white">
            <%= number_to_currency(Pago.where(estado: true).sum(:monto), unit: '$', separator: ',', delimiter: '.', precision: 0) rescue '$0' %>
          </div>
        </div>
      </div>
    </div>

    <%# Widget: Boletos vendidos %>
    <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700">
      <div class="flex items-center">
        <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center bg-blue-100 rounded-lg dark:bg-blue-900">
          <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 6a2 2 0 012-2h12a2 2 0 012 2v2a2 2 0 100 4v2a2 2 0 01-2 2H4a2 2 0 01-2-2v-2a2 2 0 100-4V6z"></path>
          </svg>
        </div>
        <div class="ml-4">
          <span class="text-sm text-gray-500 dark:text-gray-400">Boletos vendidos</span>
          <div class="text-2xl font-bold text-gray-900 dark:text-white">
            <%= Boleto.count rescue 0 %>
          </div>
        </div>
      </div>
    </div>

    <%# Widget: Eventos activos %>
    <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700">
      <div class="flex items-center">
        <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center bg-purple-100 rounded-lg dark:bg-purple-900">
          <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="ml-4">
          <span class="text-sm text-gray-500 dark:text-gray-400">Eventos activos</span>
          <div class="text-2xl font-bold text-gray-900 dark:text-white">
            <%= Evento.where(estado: 'activo').count rescue 0 %>
          </div>
        </div>
      </div>
    </div>

    <%# Widget: Usuarios registrados %>
    <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700">
      <div class="flex items-center">
        <div class="flex-shrink-0 w-12 h-12 flex items-center justify-center bg-yellow-100 rounded-lg dark:bg-yellow-900">
          <svg class="w-6 h-6 text-yellow-600 dark:text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"></path>
          </svg>
        </div>
        <div class="ml-4">
          <span class="text-sm text-gray-500 dark:text-gray-400">Usuarios registrados</span>
          <div class="text-2xl font-bold text-gray-900 dark:text-white">
            <%= User.count rescue 0 %>
          </div>
        </div>
      </div>
    </div>

  </div>

  <%# Ocupación por evento %>
<div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700 mb-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Ocupación por Evento</h3>
    <%= link_to "Ver todos", admin_eventos_path, class: "text-sm text-purple-600 hover:underline dark:text-purple-400" %>
  </div>

  <% eventos = Evento.includes(zonas: :boletos).where(estado: 'activo').limit(5) rescue [] %>
  
  <% if eventos.any? %>
    <% eventos.each do |evento| %>
      <% 
        capacidad_total = evento.zonas.sum(:capacidad)
        vendidos = evento.zonas.sum { |z| z.capacidad - z.cupos_disponibles }
        porcentaje = capacidad_total > 0 ? (vendidos.to_f / capacidad_total * 100).round : 0 
      %>
      
      <div class="mb-4">
        <div class="flex justify-between mb-1">
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300"><%= evento.nombre %></span>
          <span class="text-sm text-gray-500 dark:text-gray-400">
            <%= vendidos %>/<%= capacidad_total %> (<%= porcentaje %>%)
          </span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2.5 dark:bg-gray-700">
          <div class="h-2.5 rounded-full <%= porcentaje >= 80 ? 'bg-red-500' : porcentaje >= 50 ? 'bg-yellow-400' : 'bg-green-500' %>"
               style="width: <%= porcentaje %>%"></div>
        </div>
      </div>
    <% end %>
  <% else %>
    <p class="text-sm text-gray-500">No hay eventos activos.</p>
  <% end %>
</div>

  <%# Últimas compras %>
  <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Últimas Compras</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-600">
        <thead class="bg-gray-50 dark:bg-gray-700">
          <tr>
            <th class="p-3 text-xs font-medium text-left text-gray-500 uppercase">Orden</th>
            <th class="p-3 text-xs font-medium text-left text-gray-500 uppercase">Comprador</th>
            <th class="p-3 text-xs font-medium text-left text-gray-500 uppercase">Total</th>
            <th class="p-3 text-xs font-medium text-left text-gray-500 uppercase">Fecha</th>
            <th class="p-3 text-xs font-medium text-left text-gray-500 uppercase">Estado</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200 dark:bg-gray-800 dark:divide-gray-700">
          <% compras = Compra.includes(:pago).order(created_at: :desc).limit(8) rescue [] %>
          <% if compras.any? %>
            <% compras.each do |compra| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="p-3 text-sm font-mono text-gray-900 dark:text-white">#<%= compra.numero_orden %></td>
                <td class="p-3 text-sm text-gray-500 dark:text-gray-400"><%= compra.comprador&.email || compra.comprador_type %></td>
                <td class="p-3 text-sm font-semibold text-gray-900 dark:text-white"><%= number_to_currency(compra.precio_total, unit: '$', separator: ',', delimiter: '.', precision: 0) %></td>
                <td class="p-3 text-sm text-gray-500 dark:text-gray-400"><%= compra.fecha_compra.strftime("%d/%m/%Y") %></td>
                <td class="p-3">
                  <% if compra.pago&.estado %>
                    <span class="px-2 py-1 text-xs font-medium bg-green-100 text-green-800 rounded-full">Pagado</span>
                  <% else %>
                    <span class="px-2 py-1 text-xs font-medium bg-yellow-100 text-yellow-800 rounded-full">Pendiente</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr><td colspan="5" class="p-4 text-sm text-gray-500 text-center">No hay compras aún.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

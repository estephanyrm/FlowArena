<div class="p-4 max-w-xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Editar Usuario</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Modifica los datos de <strong><%= @usuario.email %></strong></p>
  </div>

  <%= form_with model: @usuario, url: @usuario.new_record? ? admin_usuarios_path : admin_usuario_path(@usuario), method: @usuario.new_record? ? :post : :patch, class: "space-y-5" do |f| %>

    <%# Errores %>
    <% if @usuario.errors.any? %>
      <div class="p-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400">
        <p class="font-bold mb-1"><%= pluralize(@usuario.errors.count, "error") %>:</p>
        <ul class="list-disc list-inside">
          <% @usuario.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="p-6 bg-white border border-gray-200 rounded-lg shadow-sm dark:bg-gray-800 dark:border-gray-700 space-y-4">

      <%# Avatar visual %>
      <div class="flex items-center gap-4 pb-4 border-b border-gray-200 dark:border-gray-600">
        <div class="w-12 h-12 rounded-full bg-purple-100 dark:bg-purple-900 flex items-center justify-center text-purple-700 dark:text-purple-300 font-bold text-lg">
          <%= @usuario.name&.first&.upcase || @usuario.email.first.upcase %>
        </div>
        <div>
          <p class="font-medium text-gray-900 dark:text-white"><%= @usuario.name || "Sin nombre" %></p>
          <p class="text-sm text-gray-500"><%= @usuario.email %></p>
        </div>
      </div>

      <%# Nombre %>
      <div>
        <%= f.label :name, "Nombre", class: "block mb-1 text-sm font-medium text-gray-900 dark:text-white" %>
        <%= f.text_field :name, placeholder: "Nombre completo",
            class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-purple-500 focus:border-purple-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
      </div>

      <%# Email %>
      <div>
        <%= f.label :email, "Correo electrónico", class: "block mb-1 text-sm font-medium text-gray-900 dark:text-white" %>
        <%= f.email_field :email,
            class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-purple-500 focus:border-purple-500 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
      </div>

    </div>

    <div class="flex gap-3">
      <%= f.submit "Guardar Cambios",
          class: "px-6 py-2.5 text-sm font-medium text-white bg-purple-700 rounded-lg hover:bg-purple-800 focus:ring-4 focus:ring-purple-300 cursor-pointer" %>
      <%= link_to "Cancelar", admin_usuarios_path,
          class: "px-6 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-600" %>
    </div>

  <% end %>

  <div class="mt-4">
    <%= link_to "← Volver a usuarios", admin_usuarios_path, class: "text-sm text-purple-600 hover:underline" %>
  </div>
</div>
 
<!-- Formulario para crear un nuevo usuario -->
<div class="p-4 max-w-2xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Nuevo Usuario</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Completa los datos para crear un nuevo usuario</p>
  </div>

  <%= render 'form', usuario: @usuario %>

  <div class="mt-4">
    <%= link_to "← Volver a usuarios", admin_usuarios_path, class: "text-sm text-purple-600 hover:underline" %>
  </div>
</div>

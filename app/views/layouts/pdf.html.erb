<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>Reporte Flow Arena</title>
    <style>
      body {
        font-family: 'Helvetica', 'Arial', sans-serif;
        margin: 20px;
        color: #333;
      }
      .header {
        text-align: center;
        border-bottom: 2px solid #4F46E5;
        margin-bottom: 20px;
        padding-bottom: 10px;
      }
      table {
        width: 100%;
        border-collapse: collapse;
      }
      th {
        background-color: #f3f4f6;
        text-align: left;
      }
      th, td {
        border: 1px solid #e5e7eb;
        padding: 10px;
        font-size: 12px;
      }
    </style>
  </head>
  <body>
    <div class="header">
      <h2>FLOW ARENA - SISTEMA DE GESTIÓN</h2>
    </div>
    <%= yield %>
  </body>
</html>
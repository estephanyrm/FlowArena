<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap');

  .perfil-root * { font-family: 'DM Sans', sans-serif; }
  .perfil-root .font-display, .perfil-root h1, .perfil-root h2 { font-family: 'Syne', sans-serif; }

  .perfil-root {
    min-height: 100vh;
    background: #f5f3ff;
  }

  /* Avatar iniciales */
  .avatar-circle {
    width: 80px; height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, #7c3aed, #4f46e5);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif;
    font-size: 32px; font-weight: 800; color: white;
    flex-shrink: 0;
    box-shadow: 0 4px 20px rgba(124,58,237,0.35);
  }

  .stat-card {
    background: white;
    border-radius: 16px;
    padding: 20px;
    border: 1.5px solid #ede9fe;
    text-align: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .stat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(124,58,237,0.1);
  }

  .menu-item {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 16px; border-radius: 12px;
    font-size: 14px; font-weight: 500; color: #374151;
    text-decoration: none; transition: all 0.15s;
    border: 1.5px solid transparent;
  }
  .menu-item:hover {
    background: #f5f3ff; color: #7c3aed; border-color: #ede9fe;
  }
  .menu-item.danger:hover { background: #fef2f2; color: #dc2626; border-color: #fecaca; }
  .menu-item .icon-wrap {
    width: 36px; height: 36px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    background: #f5f3ff; flex-shrink: 0;
  }
  .menu-item:hover .icon-wrap { background: #ede9fe; }
  .menu-item.danger:hover .icon-wrap { background: #fee2e2; }

  .actividad-item {
    display: flex; align-items: center; gap-12px;
    padding: 14px 0;
    border-bottom: 1px solid #f3f4f6;
    gap: 12px;
  }
  .actividad-item:last-child { border-bottom: none; }

  .badge-ok  { background: #dcfce7; color: #16a34a; }
  .badge-pen { background: #fef9c3; color: #b45309; }

  @keyframes slideIn {
    from { opacity: 0; transform: translateX(-16px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .slide-in { animation: slideIn 0.4s ease both; }
  .slide-in:nth-child(1) { animation-delay: 0.05s; }
  .slide-in:nth-child(2) { animation-delay: 0.10s; }
  .slide-in:nth-child(3) { animation-delay: 0.15s; }
  .slide-in:nth-child(4) { animation-delay: 0.20s; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-up { animation: fadeUp 0.5s ease both; }
</style>

<div class="perfil-root">

  <%# TOP BAR %>
  <div class="bg-white border-b border-purple-100 shadow-sm sticky top-0 z-10">
    <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
      <%= link_to root_path, class: "flex items-center gap-2 text-purple-600 hover:text-purple-800 transition-colors text-sm font-semibold" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Volver al inicio
      <% end %>
      <p class="text-xs text-gray-400 font-medium">Mi cuenta</p>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-[300px_1fr] gap-6">

      <div class="flex flex-col gap-4">

        <%# TARJETA DE IDENTIDAD %>
        <div class="bg-white rounded-2xl border border-purple-100 shadow-sm p-6 fade-up">
          <%# Avatar con iniciales %>
          <% initials = (current_user.name.presence || current_user.email).split(' ').first(2).map(&:first).join.upcase %>
          <div class="flex flex-col items-center text-center mb-5">
            <div class="avatar-circle mb-4"><%= initials %></div>
            <h1 class="font-display text-xl font-bold text-gray-900 leading-tight" style="font-weight:800;">
              <%= current_user.name.presence || "Usuario" %>
            </h1>
            <p class="text-sm text-gray-400 mt-1 flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <%= current_user.email %>
            </p>
            <p class="text-xs text-purple-400 mt-2 bg-purple-50 px-3 py-1 rounded-full">
              Miembro desde <%= I18n.l(current_user.created_at, format: :month_year) rescue "—" %>
            </p>
          </div>

          <%# Stats rápidas %>
          <% total_compras  = current_user.compras.count %>
          <% total_boletos  = current_user.compras.joins(:boletos).count %>
          <% compras_pagas  = current_user.compras.where(estado: 'completado').count %>
          <div class="grid grid-cols-3 gap-2">
            <div class="stat-card">
              <p class="font-display text-2xl font-bold text-purple-700" style="font-weight:800;"><%= total_compras %></p>
              <p class="text-xs text-gray-400 mt-0.5">Compras</p>
            </div>
            <div class="stat-card">
              <p class="font-display text-2xl font-bold text-purple-700" style="font-weight:800;"><%= total_boletos %></p>
              <p class="text-xs text-gray-400 mt-0.5">Boletos</p>
            </div>
            <div class="stat-card">
              <p class="font-display text-2xl font-bold text-green-600" style="font-weight:800;"><%= compras_pagas %></p>
              <p class="text-xs text-gray-400 mt-0.5">Pagados</p>
            </div>
          </div>
        </div>

        <%# NAVEGACIÓN %>
        <div class="bg-white rounded-2xl border border-purple-100 shadow-sm p-3 fade-up" style="animation-delay:0.1s">
          <p class="text-xs font-bold text-gray-400 uppercase tracking-widest px-3 mb-2">Mi cuenta</p>

          <%= link_to mis_compras_path, class: "menu-item slide-in" do %>
            <div class="icon-wrap">
              <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
              </svg>
            </div>
            Mis boletos
            <svg class="w-4 h-4 text-gray-300 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          <% end %>

          <%= link_to edit_user_registration_path, class: "menu-item slide-in" do %>
            <div class="icon-wrap">
              <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
            </div>
            Editar perfil
            <svg class="w-4 h-4 text-gray-300 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          <% end %>

          <%= link_to root_path, class: "menu-item slide-in" do %>
            <div class="icon-wrap">
              <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            Ver eventos
            <svg class="w-4 h-4 text-gray-300 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          <% end %>

          <div class="border-t border-gray-100 my-2"></div>

          <%= link_to destroy_user_session_path, data: { "turbo-method": :delete }, class: "menu-item danger slide-in" do %>
            <div class="icon-wrap">
              <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
              </svg>
            </div>
            Cerrar sesión
          <% end %>
        </div>

      </div>

      <div class="flex flex-col gap-5">

        <div class="bg-white rounded-2xl border border-purple-100 shadow-sm overflow-hidden fade-up" style="animation-delay:0.15s">
          <div class="px-6 py-4 border-b border-purple-50 flex items-center justify-between">
            <h2 class="font-display font-bold text-gray-900" style="font-weight:700;">Actividad reciente</h2>
            <%= link_to mis_compras_path, class: "text-xs text-purple-500 font-semibold hover:underline" do %>
              Ver todo →
            <% end %>
          </div>

          <% compras_recientes = current_user.compras.includes(:boletos, :pago, zonas: :evento).order(created_at: :desc).limit(5) %>

          <% if compras_recientes.empty? %>
            <div class="px-6 py-12 text-center">
              <p class="text-gray-400 text-sm">Aún no has realizado ninguna compra.</p>
              <%= link_to "Explorar eventos →", root_path, class: "text-purple-600 font-semibold text-sm hover:underline mt-2 inline-block" %>
            </div>
          <% else %>
            <div class="px-6">
              <% compras_recientes.each do |compra| %>
                <%
                  boleto_r   = compra.boletos.first
                  zona_r     = boleto_r&.zona
                  evento_r   = zona_r&.evento
                  es_pago    = compra.estado == "completado" || compra.pago&.estado == true
                  color_r    = { "Diamante" => "#7C3AED", "VIP" => "#2563EB", "Preferencial" => "#059669", "General" => "#D97706" }[zona_r&.nombre] || "#7C3AED"
                %>
                <div class="actividad-item">
                  <%# Dot de color zona %>
                  <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: <%= color_r %>1a">
                    <span class="w-3 h-3 rounded-full" style="background: <%= color_r %>"></span>
                  </div>

                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-gray-800 truncate">
                      <%= evento_r&.nombre || "Evento" %>
                    </p>
                    <p class="text-xs text-gray-400 mt-0.5">
                      Zona <%= zona_r&.nombre || "—" %> ·
                      <%= compra.cantidad %> boleto<%= compra.cantidad > 1 ? "s" : "" %> ·
                      <%= compra.created_at.strftime("%d/%m/%Y") %>
                    </p>
                  </div>

                  <div class="flex flex-col items-end gap-1.5 flex-shrink-0">
                    <span class="text-xs font-bold px-2 py-0.5 rounded-full <%= es_pago ? 'badge-ok' : 'badge-pen' %>">
                      <%= es_pago ? "Pagado" : "Pendiente" %>
                    </span>
                    <% if es_pago %>
                      <%= link_to "Ver →", compra_path(compra), class: "text-xs text-purple-500 font-semibold hover:underline" %>
                    <% else %>
                      <%= link_to "Pagar →", pago_compra_path(compra), class: "text-xs text-amber-500 font-semibold hover:underline" %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <% total_gastado = current_user.compras.where(estado: 'completado').sum(:precio_total).to_i %>
        <% if total_gastado > 0 %>
          <div class="rounded-2xl p-6 fade-up flex items-center justify-between gap-4" style="background: linear-gradient(135deg, #7c3aed, #4f46e5); animation-delay:0.2s">
            <div>
              <p class="text-purple-200 text-xs font-semibold uppercase tracking-widest mb-1">Total invertido en experiencias</p>
              <p class="font-display text-3xl font-bold text-white" style="font-weight:800;">
                $<%= ActiveSupport::NumberHelper.number_to_delimited(total_gastado, delimiter: '.') %>
                <span class="text-purple-300 text-base font-normal">COP</span>
              </p>
            </div>
            <svg class="w-12 h-12 text-purple-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
            </svg>
          </div>
        <% end %>
        <div class="bg-white rounded-2xl border border-purple-100 shadow-sm p-6 fade-up" style="animation-delay:0.25s">
          <h2 class="font-display font-bold text-gray-900 mb-4" style="font-weight:700;">Datos de la cuenta</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-1">Nombre completo</p>
              <p class="font-semibold text-gray-800"><%= current_user.name.presence || "—" %></p>
            </div>
            <div>
              <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-1">Correo electrónico</p>
              <p class="font-semibold text-gray-800"><%= current_user.email %></p>
            </div>
            <div>
              <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-1">Contraseña</p>
              <p class="font-semibold text-gray-800">••••••••</p>
            </div>
            <div>
              <p class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-1">Miembro desde</p>
              <p class="font-semibold text-gray-800"><%= I18n.l(current_user.created_at, format: :month_year) rescue "—" %></p>
            </div>
          </div>
          <div class="mt-5 pt-4 border-t border-gray-100">
            <%= link_to edit_user_registration_path, class: "inline-flex items-center gap-2 text-sm font-semibold text-purple-600 hover:text-purple-800 hover:underline transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              Editar mis datos
            <% end %>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

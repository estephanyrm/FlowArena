<div class="flex flex-col bg-purple-100 min-h-screen items-center justify-center p-2 sm:p-4 pb-20">
  <%# Logo %>
  <div class="flex justify-center items-center text-purple-600 py-6">
    <a href="<%= root_path %>", class="hover:opacity-80 transition-opacity">
      <%= inline_svg("logo.svg") %>
    </a>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl max-w-4xl w-full overflow-hidden transition-all duration-300">
    <div class="flex flex-row min-h-[300px]">
      
      <div id="perfil-menu-custom" class="justify-center w-1/3 sm:w-1/4 bg-gray-50 dark:bg-gray-900/50 flex flex-col items-stretch border-r border-gray-100 py-6">
        <div class="flex flex-col space-y-1 ">
          <%= render "layouts/header_menu_items" %>
        </div>
      </div>

      <div class="w-2/3 sm:w-3/4 p-4 sm:p-10 flex flex-col justify-center bg-white dark:bg-gray-800">
        <div class="space-y-6">
          <div>
            <h2 class="text-[10px] sm:text-xs uppercase tracking-widest text-purple-500 font-bold mb-1">Nombre:</h2>
            <p class="text-lg sm:text-3xl text-gray-800 dark:text-white font-medium italic">
              <%= current_user.name.presence || "Usuario" %>
            </p>
          </div>

          <div class="pt-4 border-t border-gray-100">
            <h2 class="text-[10px] sm:text-xs uppercase tracking-widest text-purple-500 font-bold mb-1">Correo:</h2>
            <div class="flex items-center text-sm sm:text-xl text-gray-600 dark:text-gray-300 italic">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 sm:h-6 sm:w-6 mr-2 text-purple-400" viewBox="0 0 20 20" fill="currentColor">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
              </svg>
              <%= current_user.email %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%= link_to root_path, class: "block w-full px-4 py-2 text-sm font-semibold text-purple-700 hover:bg-purple-50 border-b border-gray-100 flex items-center gap-2", role: "menuitem" do %>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
  Inicio
<% end %>
<% if user_signed_in? %>
  <%# Indicador de sesión activa %>
  <div class="px-4 py-3 border-b border-gray-100">
    <div class="flex items-center gap-2">
      <span class="inline-block w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
      <span class="text-xs font-semibold text-gray-700 truncate">
        <%= current_user.name.presence || current_user.email %>
      </span>
    </div>
    <p class="text-[11px] text-gray-400 mt-0.5 pl-4">Sesión activa</p>
  </div>
  <%= link_to "Mi perfil",      profile_path,                class: "block w-full px-4 py-2 text-sm text-gray-700 hover:bg-purple-50 hover:text-purple-700 transition-colors", role: "menuitem" %>
  <%= link_to "Editar perfil",  edit_user_registration_path, class: "block w-full px-4 py-2 text-sm text-gray-700 hover:bg-purple-50 hover:text-purple-700 transition-colors", role: "menuitem" %>
  <%= link_to "Mis boletos",    mis_compras_path,            class: "block w-full px-4 py-2 text-sm text-gray-700 hover:bg-purple-50 hover:text-purple-700 transition-colors", role: "menuitem" %>
  <div class="border-t border-gray-100 mt-1">
    <%= link_to "Cerrar sesión", destroy_user_session_path,
                data: { "turbo-method": :delete },
                class: "block w-full px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors",
                role: "menuitem" %>
  </div>
<% else %>
  <div class="px-4 py-2 border-b border-gray-100">
    <p class="text-xs text-gray-400">No has iniciado sesión</p>
  </div>
  <%= link_to "Iniciar sesión", new_user_session_path,       class: "block w-full px-4 py-2 text-sm text-gray-700 hover:bg-purple-50 hover:text-purple-700 transition-colors", role: "menuitem" %>
  <%= link_to "Registrarme",    new_user_registration_path,  class: "block w-full px-4 py-2 text-sm text-gray-700 hover:bg-purple-50 hover:text-purple-700 transition-colors", role: "menuitem" %>
<% end %>
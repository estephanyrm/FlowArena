<!-- ============================================
Vista principal del sistema
Muestra eventos disponibles
============================================ -->
<div class="bg-purple-100"> 

  <div id="default-carousel" class="relative w-full" data-carousel="slide">
  
    <%# Contenedor de slides %>
    <div class="relative w-full aspect-[16/9] md:aspect-[21/9] overflow-hidden rounded-2xl bg-gray-900">
      <% @carousel_events.each_with_index do |event, index| %>
        <div class="<%= index == 0 ? 'block' : 'hidden' %> h-full w-full duration-700 ease-in-out" data-carousel-item>
          <%= image_tag event.imagen, 
              class: "absolute block w-full h-full object-contain" %>
          
          <%# Gradiente más oscuro para ocultar el salto entre imagen y fondo %>
          <div class="absolute bottom-0 p-8 bg-gradient-to-t from-black/95 via-black/40 to-transparent w-full text-white">
          </div>

        </div>
      <% end %>
    </div>

  <%# Indicadores Economicas %>
  <div class="absolute z-30 flex -translate-x-1/2 bottom-4 left-1/2 space-x-3">
    <% @carousel_events.each_with_index do |_, index| %>
      <button type="button" 
              class="w-3 h-3 rounded-full transition-all <%= index == 0 ? 'bg-white w-8' : 'bg-white/50' %>" 
              aria-current="<%= index == 0 ? 'true' : 'false' %>" 
              aria-label="Slide <%= index + 1 %>" 
              data-carousel-slide-to="<%= index %>">
      </button>
    <% end %>
  </div>

    <%# Botón anterior %>
    <button type="button" class="absolute top-0 start-0 z-30 flex items-center justify-center h-full px-4 group" data-carousel-prev>
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/30 group-hover:bg-white/50">
        <svg class="w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 19-7-7 7-7"/>
        </svg>
      </span>
    </button>

    <%# Botón siguiente %>
    <button type="button" class="absolute top-0 end-0 z-30 flex items-center justify-center h-full px-4 group" data-carousel-next>
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/30 group-hover:bg-white/50">
        <svg class="w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7"/>
        </svg>
      </span>
    </button>

  </div>

  <%# Items, eventos %>
<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <h2 class="text-3xl font-extrabold tracking-tight text-gray-900 mb-8 border-l-4 border-purple-600 pl-4">
    Próximos Eventos
  </h2>

  <div class="grid grid-cols-1 gap-x-6 gap-y-12 sm:grid-cols-2 lg:grid-cols-4" role="list">
    <% for event in @events %>
      <div class="group flex flex-col bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
        
        <%# Contenedor de Imagen %>
        <div class="relative w-full aspect-video bg-gray-100 flex items-center justify-center overflow-hidden">
          <%= image_tag "#{event.imagen}", 
              alt: "Imagen del evento", 
              class: "max-w-full max-h-full object-contain transition-transform duration-500 group-hover:scale-105" %>
        </div>
        
        <div class="p-5 flex flex-col flex-grow">
          <div class="flex flex-row items-center justify-between w-full mb-3">
            <%# Fecha %>
            <p class="text-xs font-bold text-purple-700 uppercase tracking-wider">
              <%= I18n.l(event.fecha, format: "%d %b, %Y") %>
            </p>
            
            <%# Hora %>
            <p class="text-xs font-bold text-purple-700">
              <%= event.hora.strftime("%I:%M %p") %>
            </p>
          </div>

          <%# Título del Evento %>
          <h3 class="text-lg font-black text-gray-900 leading-tight mb-2">
            <%= event.nombre %>
          </h3>
          
          <%# Espacio flexible %>
          <div class="flex-grow">
            <p class="text-sm text-gray-500 line-clamp-2 italic">
              <%= event.descripcion %>
            </p>
          </div>

          <%# Botón que lleva a la pagina del evento %>
          <div class="mt-6">
            <span class="inline-flex w-full justify-center items-center rounded-xl bg-purple-600 px-4 py-3 text-sm font-black text-white shadow-sm hover:bg-purple-700 transition-colors cursor-pointer">
              + info
            </span>
          </div>
        </div>
        </div> 
      <% end %>
  </div>
</div>
</div>
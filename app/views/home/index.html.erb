<div class="bg-purple-100">
  <div id="default-carousel" class="relative w-full" data-carousel="slide">
    
    <%# 1. Contenedor de slides %>
    <div class="relative h-64 overflow-hidden md:h-[500px]">
      <%# Slide 1 %>
      <div class="hidden duration-700 ease-in-out" data-carousel-item="active">
        <%= image_tag "ejemplo1.jpg", 
            class: "absolute block w-full h-full object-cover -translate-x-1/2 -translate-y-1/2 top-1/2 left-1/2", 
            alt: "Slide 1" %>
      </div>

      <%# Slide 2 %>
      <div class="hidden duration-700 ease-in-out" data-carousel-item>
        <%= image_tag "ejemplo2.png", 
            class: "absolute block w-full h-full object-cover -translate-x-1/2 -translate-y-1/2 top-1/2 left-1/2", 
            alt: "Slide 2" %>
      </div>

      <%# Slide 3 %>
      <div class="hidden duration-700 ease-in-out" data-carousel-item>
        <%= image_tag "ejemplo3.jpg", 
            class: "absolute block w-full h-full object-cover -translate-x-1/2 -translate-y-1/2 top-1/2 left-1/2", 
            alt: "Slide 3" %>
      </div>
    </div>

    <%# 2. Indicadores  %>
    <div class="absolute z-30 flex -translate-x-1/2 bottom-5 left-1/2 space-x-3">
      <button type="button" class="w-3 h-3 rounded-full bg-white" aria-label="Slide 1" data-carousel-slide-to="0"></button>
      <button type="button" class="w-3 h-3 rounded-full bg-white/50" aria-label="Slide 2" data-carousel-slide-to="1"></button>
      <button type="button" class="w-3 h-3 rounded-full bg-white/50" aria-label="Slide 3" data-carousel-slide-to="2"></button>
    </div>

    <%# 3. Botón Anterior %>
    <button type="button" class="absolute top-0 start-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group focus:outline-none" data-carousel-prev>
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/30 group-hover:bg-white/50">
        <svg class="w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="m15 19-7-7 7-7"/>
        </svg>
      </span>
    </button>

    <%# 4. Botón Siguiente %>
    <button type="button" class="absolute top-0 end-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group focus:outline-none" data-carousel-next>
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/30 group-hover:bg-white/50">
        <svg class="w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7"/>
        </svg>
      </span>
    </button>

  </div> 

    <%# Items, eventos %>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-extrabold tracking-tight text-gray-900 mb-8">Próximos Eventos</h2>

    <div class="grid grid-cols-1 gap-x-6 gap-y-12 sm:grid-cols-2 lg:grid-cols-4" role="list">
      <% 10.times do %>
        <div class="group flex flex-col">
          <div class="relative aspect-video w-full overflow-hidden rounded-xl bg-gray-200 shadow-sm transition-all duration-300 group-hover:shadow-lg">
            <%= image_tag "ejemplo2.png", 
                alt: "Imagen del evento", 
                class: "h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-105" %>
          </div>
          
          <div class="mt-4 flex flex-col flex-grow">
            <div class="flex justify-between items-start">
              <div class="flex-1">
                <h3 class="text-lg font-bold text-gray-900 leading-tight">
                  <a href="#">
                    <span aria-hidden="true" class="absolute inset-0"></span>
                    EDC Colombia 2026
                  </a>
                </h3>
                <p class="mt-1 text-sm font-medium text-purple-700">10 de octubre de 2026</p>
                <p class="text-xs text-gray-500 italic">pequeña descripcion sobre el evento.........</p>
              </div>
              <p class="text-lg font-bold text-gray-900">11:30</p>
            </div>
            <div class="mt-4">
              <span class="inline-flex w-full justify-center items-center rounded-lg bg-purple-600 px-4 py-2 text-sm font-bold text-white shadow-sm hover:bg-purple-700 transition-colors">
                + info
              </span>
            </div>
          </div>
        </div> 
      <% end %>
    </div>
  </div>
</div>
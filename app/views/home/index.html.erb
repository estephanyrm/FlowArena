<div class="bg-purple-100 min-h-screen"> 

  <%# carrusel %>
  <div id="default-carousel" class="relative w-full" data-carousel="slide">
    <div class="relative w-full aspect-[16/9] md:aspect-[21/9] overflow-hidden rounded-2xl bg-gray-900">
      <% @carousel_events.each_with_index do |event, index| %>
        <div class="<%= index == 0 ? 'block' : 'hidden' %> h-full w-full duration-700 ease-in-out" data-carousel-item>
          <%= link_to pagina_eventos_path(id: event.id), class: "block w-full h-full relative" do %>
            <%= image_tag event.imagen, class: "absolute block w-full h-full object-contain" %>
            <div class="absolute bottom-0 p-8 bg-gradient-to-t from-black/95 via-black/40 to-transparent w-full text-white"></div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Indicadores %>
    <div class="absolute z-30 flex -translate-x-1/2 bottom-4 left-1/2 space-x-3">
      <% @carousel_events.each_with_index do |_, index| %>
        <button type="button" class="w-3 h-3 rounded-full transition-all <%= index == 0 ? 'bg-white w-8' : 'bg-white/50' %>" data-carousel-slide-to="<%= index %>"></button>
      <% end %>
    </div>

    <%# Botones de navegación %>
    <button type="button" class="absolute top-0 start-0 z-30 flex items-center justify-center h-full px-4 group" data-carousel-prev>
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/30 group-hover:bg-white/50">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 19-7-7 7-7"/></svg>
      </span>
    </button>
    <button type="button" class="absolute top-0 end-0 z-30 flex items-center justify-center h-full px-4 group" data-carousel-next>
      <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/30 group-hover:bg-white/50">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7"/></svg>
      </span>
    </button>
  </div> 

  <%# bloque de eventos %>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-extrabold tracking-tight text-gray-900 mb-8 border-l-4 border-purple-600 pl-4">
      <%= params[:buscar].present? ? "Resultados para: #{params[:buscar]}" : "Próximos Eventos" %>
    </h2>

    <% if @events.any? %>
      <div class="grid grid-cols-1 gap-x-6 gap-y-12 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        <% @events.each do |event| %>
        <%= link_to pagina_eventos_path(id: event.id), class: "group" do %>
          <div class="flex flex-col bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all h-full">
            
            <div class="relative w-full aspect-video bg-gray-900 flex items-center justify-center overflow-hidden">
              <%= image_tag event.imagen, class: "max-w-full max-h-full object-contain transition-transform duration-500 group-hover:scale-105" %>
            </div>
            
            <div class="p-5 flex flex-col flex-grow">
              <div class="flex justify-between mb-3">
                <p class="text-xs font-bold text-purple-700 uppercase"><%= I18n.l(event.fecha, format: "%d %b, %Y") %></p>
                <p class="text-xs font-bold text-purple-700"><%= event.hora.strftime("%I:%M %p") %></p>
              </div>

              <h3 class="text-lg font-black text-gray-900 leading-tight mb-2"><%= event.nombre %></h3>
              
              <div class="flex-grow">
                <p class="text-sm text-gray-500 line-clamp-2 italic"><%= event.descripcion %></p>
              </div>

              <div class="mt-6">
                <span class="inline-flex w-full justify-center items-center rounded-xl bg-purple-600 px-4 py-3 text-sm font-black text-white hover:bg-purple-700 transition-colors">
                  + info
                </span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
    <% else %>
      <div class="text-center py-20">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
        </svg>
        <h3 class="mt-2 text-sm font-semibold text-gray-900">No se encontraron eventos</h3>
        <p class="mt-1 text-sm text-gray-500">Intenta buscar con otros términos o <%= link_to "ver todos los eventos", root_path, class: "text-purple-600 hover:text-purple-500 font-medium" %>.</p>
      </div>
    <% end %>
  </div>

</div>